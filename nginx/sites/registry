upstream docker-registry {
    server 127.0.0.1:4444;
}

map "$request_method:$remote_user" $deny_push {
    default 1;

    "~^(GET|HEAD):" 0;
    "~^(POST|PUT|PATCH|DELETE):cicd$" 0;
    "~^(POST|PUT|PATCH|DELETE):kevindev64$" 0;
}

map $upstream_http_docker_distribution_api_version $docker_distribution_api_version {
    '' 'registry/2.0';
}


server {
    server_name registry.certsirius.ru;

    # disable any limits to avoid HTTP 413 for large image uploads
    client_max_body_size 0;

    # required to avoid HTTP 411
    chunked_transfer_encoding on;

    location /v2/ {
        if ($http_user_agent ~ "^(docker\/1\.(3|4|5(?!\.[0-9]-dev))|Go ).*$" ) {
            return 404;
        }

        # To add basic authentication to v2 use auth_basic setting.
        auth_basic "basic-realm";
        auth_basic_user_file /opt/siriusdocs/ci-cd/registry-auth/htpasswd;

        add_header 'Docker-Distribution-Api-Version' $docker_distribution_api_version always;

        proxy_pass                          http://docker-registry;

        proxy_set_header  Host              $http_host;   # required for docker client's sake
        proxy_set_header  X-Real-IP         $remote_addr; # pass on real client's IP
        proxy_set_header  X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header  X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_read_timeout                  900;
        proxy_pass_request_body on;

        if ($deny_push) {
            return 403 "Push access denied for this user";
        }
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/certsirius.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/certsirius.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}


server {
    if ($host = registry.certsirius.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name registry.certsirius.ru;
    return 404; # managed by Certbot


}