upstream frontend {
  keepalive 32; 
  server 127.0.0.1:8080; 
}

server {      
    server_name     certsirius.ru;  

    access_log      /var/log/nginx/sd.access.log;
    error_log       /var/log/nginx/sd.error.log;

    location / {
        proxy_pass         http://frontend;
  
        proxy_set_header   Host              $http_host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_max_temp_file_size 0;

        # client_max_body_size       10m;
        # client_body_buffer_size    128k;
  
        proxy_connect_timeout      90;
        proxy_send_timeout         90;
        proxy_read_timeout         90;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/certsirius.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/certsirius.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    if ($host = certsirius.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

      
    server_name certsirius.ru;
  
    listen 80 default_server;
    return 404; # managed by Certbot


}